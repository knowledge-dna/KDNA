{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KDNA_Scenarios",
  "type": "object",
  "required": ["meta"],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "version",
        "domain",
        "created",
        "purpose",
        "load_condition"
      ],
      "properties": {
        "version": { "type": "string" },
        "domain": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "created": { "type": "string" },
        "purpose": { "type": "string" },
        "load_condition": { "type": "string" }
      },
      "additionalProperties": true
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "trigger_signal": {
            "type": "string",
            "description": "Deprecated: use trigger_signals (array) instead. Kept for backward compatibility."
          },
          "trigger_signals": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Signals that trigger this scene."
          },
          "negative_signals": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Signals that explicitly exclude this scene."
          },
          "classification_rule": {
            "type": "string",
            "description": "Rule for classifying input into this scene."
          },
          "risk_level": {
            "type": "string",
            "description": "Risk level associated with this scene."
          },
          "expected_judgment_shift": {
            "type": "string",
            "description": "How judgment should shift when this scene is detected."
          },
          "sub_scenarios": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "trap_belief", "action_template", "expected_result"],
              "properties": {
                "id": { "type": "string" },
                "trap_belief": { "type": "string" },
                "three_questions": {
                  "type": "object",
                  "required": ["belief", "state", "need"],
                  "properties": {
                    "belief": { "type": "string" },
                    "state": { "type": "string" },
                    "need": { "type": "string" }
                  }
                },
                "action_template": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "replace": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["avoid", "use"],
                    "properties": {
                      "avoid": { "type": "string" },
                      "use": { "type": "string" }
                    }
                  }
                },
                "expected_result": { "type": "string" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
