{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KDNA_Evolution",
  "type": "object",
  "required": ["meta"],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "version",
        "domain",
        "created",
        "purpose",
        "load_condition"
      ],
      "properties": {
        "version": { "type": "string" },
        "domain": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "created": { "type": "string" },
        "purpose": { "type": "string" },
        "load_condition": { "type": "string" }
      },
      "additionalProperties": true
    },
    "maturity_stages": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "indicators"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "indicators": {
            "type": "array",
            "items": { "type": "string" }
          },
          "changed_judgments": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Judgments that changed at this stage."
          },
          "deprecated_axioms": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Axioms that are no longer held at this stage."
          },
          "new_failure_modes": {
            "type": "array",
            "items": { "type": "string" },
            "description": "New failure patterns that emerge at this stage."
          },
          "eval_results": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Evaluation results associated with this stage."
          },
          "known_limitations": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Known limitations at this stage."
          }
        },
        "additionalProperties": true
      }
    },
    "evolution_layers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "capability", "from_stage", "to_stage"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "capability": { "type": "string" },
          "from_stage": { "type": "string" },
          "to_stage": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "measurement": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "what", "how", "threshold"],
        "properties": {
          "id": { "type": "string" },
          "what": { "type": "string" },
          "how": { "type": "string" },
          "threshold": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "changed_judgments": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Domain-wide judgment changes across versions."
    },
    "deprecated_axioms": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Axioms deprecated across the domain's evolution."
    },
    "new_failure_modes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "New failure modes discovered over time."
    },
    "eval_results": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Evaluation results across versions."
    },
    "known_limitations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Known limitations of the domain's judgment model."
    }
  },
  "additionalProperties": true
}
