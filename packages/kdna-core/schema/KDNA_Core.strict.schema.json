{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KDNA_Core",
  "type": "object",
  "required": [
    "meta",
    "axioms",
    "ontology",
    "frameworks",
    "core_structure",
    "stances"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "version",
        "domain",
        "created",
        "purpose",
        "load_condition"
      ],
      "properties": {
        "version": {
          "type": "string"
        },
        "domain": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "created": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "load_condition": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "highest_question": {
      "type": "string",
      "description": "The highest-order question this domain answers."
    },
    "worldview": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Default assumptions about how the world works in this domain."
    },
    "judgment_role": {
      "type": "object",
      "properties": {
        "acts_as": {
          "type": "string"
        },
        "does_not_act_as": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "responsibility": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "value_order": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Priority ordering of values in this domain."
    },
    "axioms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "one_sentence",
          "full_statement",
          "why",
          "applies_when",
          "does_not_apply_when",
          "failure_risk",
          "confidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "one_sentence": {
            "type": "string"
          },
          "full_statement": {
            "type": "string"
          },
          "why": {
            "type": "string"
          },
          "confidence": {
            "type": "string"
          },
          "evidence_type": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "applies_when": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "does_not_apply_when": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "failure_risk": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "ontology": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "one_sentence",
          "essence",
          "boundary",
          "trigger_signal"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "one_sentence": {
            "type": "string"
          },
          "essence": {
            "type": "string"
          },
          "boundary": {
            "type": "string"
          },
          "trigger_signal": {
            "type": "string"
          },
          "applies_when": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "does_not_apply_when": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "frameworks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "when_to_use",
          "steps"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "when_to_use": {
            "type": "string"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "applies_when": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "does_not_apply_when": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "core_structure": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "via"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "via": {
            "type": "string"
          },
          "applies_when": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "does_not_apply_when": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "stances": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "required": [
              "stance"
            ],
            "properties": {
              "stance": {
                "type": "string"
              },
              "applies_when": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "does_not_apply_when": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        ]
      }
    }
  },
  "additionalProperties": true
}
