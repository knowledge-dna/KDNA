{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KDNA_Patterns",
  "type": "object",
  "required": [
    "meta",
    "terminology",
    "misunderstandings",
    "self_check"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "version",
        "domain",
        "created",
        "purpose",
        "load_condition"
      ],
      "properties": {
        "version": {
          "type": "string"
        },
        "domain": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "created": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "load_condition": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "terminology": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "standard_terms": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "term",
              "definition"
            ],
            "properties": {
              "term": {
                "type": "string"
              },
              "definition": {
                "type": "string"
              },
              "applies_when": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "does_not_apply_when": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "preferred_terms": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "term",
              "definition"
            ],
            "properties": {
              "term": {
                "type": "string"
              },
              "definition": {
                "type": "string"
              },
              "applies_when": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "does_not_apply_when": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "banned_terms": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "term",
              "why",
              "replace_with"
            ],
            "properties": {
              "term": {
                "type": "string"
              },
              "why": {
                "type": "string"
              },
              "replace_with": {
                "type": "string"
              },
              "applies_when": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "does_not_apply_when": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "aesthetic_preferences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "prefer",
          "avoid"
        ],
        "properties": {
          "prefer": {
            "type": "string"
          },
          "avoid": {
            "type": "string"
          },
          "signals_good": {
            "type": "string"
          },
          "signals_bad": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "boundaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule",
          "why"
        ],
        "properties": {
          "rule": {
            "type": "string"
          },
          "why": {
            "type": "string"
          },
          "must_not_do": {
            "type": "string"
          },
          "acceptable_exception": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "risk_model": {
      "type": "object",
      "properties": {
        "highest_risk_errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptable_errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "must_block_when": {
          "type": "string"
        },
        "warn_when": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "misunderstandings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "wrong",
          "correct",
          "key_distinction",
          "why"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "wrong": {
            "type": "string"
          },
          "correct": {
            "type": "string"
          },
          "key_distinction": {
            "type": "string"
          },
          "why": {
            "type": "string"
          },
          "confidence": {
            "type": "string"
          },
          "evidence_type": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "applies_when": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "does_not_apply_when": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "failure_risk": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "self_check": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "required": [
              "question"
            ],
            "properties": {
              "question": {
                "type": "string"
              },
              "applies_when": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "counterexamples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "bad_example",
          "why_bad"
        ],
        "properties": {
          "bad_example": {
            "type": "string"
          },
          "why_bad": {
            "type": "string"
          },
          "violated_axioms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "better_direction": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
