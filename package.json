{
  "name": "@aikdna/kdna-monorepo",
  "version": "0.7.0",
  "private": true,
  "description": "KDNA protocol specification, core library, and domain registry.",
  "type": "commonjs",
  "scripts": {
    "lint": "eslint packages/kdna-core/src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:examples": "echo 'Use npx kdna dev validate on individual domain repos'",
    "validate:examples": "echo 'Use npx kdna dev validate on individual domain repos'",
    "validate:runtime-contract": "node scripts/validate-runtime-contract.js",
    "test": "npm --workspace @aikdna/kdna-core test",
    "conformance": "node conformance/run.mjs",
    "certify:asset-loader": "node conformance/run.mjs --profile asset-loader",
    "pretest": "npm install --ignore-scripts"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aikdna/kdna.git"
  },
  "homepage": "https://aikdna.com",
  "bugs": {
    "url": "https://github.com/aikdna/kdna/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@aikdna/kdna-cli": "^0.18.0",
    "@eslint/js": "^9.39.0",
    "eslint": "^9.39.0",
    "prettier": "^3.8.3"
  }
}
